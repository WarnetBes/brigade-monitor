# ================================================
# brigade-monitor — шаблон конфигурации
# Скопируйте в .env и заполните своими данными
# НИКОГДА не заливайте .env в git!
# ================================================

# ── Telegram API (получить на my.telegram.org) ──────────
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# StringSession (запустить session_security.py generate)
TG_SESSION_STRING=

# Ваш личный Telegram ID (узнать через @userinfobot)
BRIGADE_LEADER_ID=123456789

# ID групп, разделёные запятой (отрицательные для супергрупп)
TG_CHATS=-1001234567890,-1009876543210,-1001122334455

# Telegram Bot Token (для отправки уведомлений лично вам)
TG_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Яндекс Мессенджер ────────────────────────────────
YANDEX_BOT_TOKEN=
YANDEX_WEBHOOK_SECRET=

# ── Flask ──────────────────────────────────────────────────
FLASK_SECRET_KEY=измените_на_случайную_строку
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# ── OCR ─────────────────────────────────────────────────────
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux: /usr/bin/tesseract
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGE=rus+eng

# ── Excel экспорт ────────────────────────────────────────
EXPORT_DIR=exports
EXPORT_INTERVAL_HOURS=2
EXPORT_KEEP_FILES=48

# ── VPS / сервер ──────────────────────────────────────────
# URL вашего сервера (для Telegram webhook)
SERVER_URL=https://your-domain.com

# Таймзона
TZ=Europe/Moscow
